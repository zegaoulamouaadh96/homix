# Homix Production Environment Variables
# Copy this file to .env and update with your values

# Database
DB_PASSWORD=homix_secure_password_change_me_in_production

# JWT Secrets (use strong random strings)
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_32_chars
ADMIN_JWT_SECRET=change_this_to_a_strong_random_admin_secret_at_least_32_chars

# Face Recognition
FACE_DEVICE_TOKEN=prod-face-device-token-change-me-2024
FACE_REQUIRE_HTTPS=true
FACE_DISTANCE_THRESHOLD=0.42
FACE_MIN_REGISTER_FRAMES=6
FACE_MAX_REGISTER_FRAMES=14

# MQTT
MQTT_ENABLE_WS=true
MQTT_ENABLE_TCP=true
MQTT_PORT=1883

# Email (SMTP) - for sending house codes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@homix.systems

# AI Service
HOMIX_AI_URL=http://ai:5000

# Redis (caching)
REDIS_URL=redis://redis:6379

# Rate Limiting
FACE_RATE_WINDOW_MS=60000
FACE_RATE_MAX=40

# File Upload Limits
JSON_BODY_LIMIT=20mb
